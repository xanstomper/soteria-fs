#!/usr/bin/env ruby
# frozen_string_literal: true

require "thor"
require_relative "../lib/soteria"

module Soteria
  # Main CLI — Ruby frontend for the Soteria encrypted security platform.
  # Delegates cryptographic operations to the Rust core via CoreBridge.
  class CLI < Thor
    desc "version", "Show Soteria version"
    def version
      puts "Soteria v#{Soteria::VERSION}"
      puts "Rust core: #{Soteria.binary_available? ? 'available' : 'not found'}"
    end

    desc "setup", "Run the interactive setup wizard"
    option :mode, type: :string, enum: %w[personal professional fortress],
                  default: "personal", desc: "Security mode"
    def setup
      installer = Soteria::Installer.new
      installer.run_setup
    end

    desc "encrypt SRC INTO NAME", "Encrypt a file"
    option :passphrase, required: true, desc: "Encryption passphrase"
    option :fast_kdf, type: :boolean, default: false, desc: "Use fast KDF (testing only)"
    def encrypt(src, into, name)
      result = Soteria::CoreBridge.encrypt(
        src: src, into: into, name: name,
        passphrase: options[:passphrase],
        fast_kdf: options[:fast_kdf]
      )
      puts JSON.pretty_generate(result)
    end

    desc "decrypt FROM NAME OUTPUT", "Decrypt a volume"
    option :passphrase, desc: "Decryption passphrase"
    option :key_file, desc: "Path to a 32-byte raw key file"
    def decrypt(from, name, output)
      result = Soteria::CoreBridge.decrypt(
        from: from, name: name,
        passphrase: options[:passphrase],
        key_file: options[:key_file],
        output: output
      )
      puts JSON.pretty_generate(result)
    end

    desc "keygen OUT", "Generate a keypair"
    option :scheme, type: :string, enum: %w[ml-kem-768 ml-dsa-65],
                    default: "ml-kem-768", desc: "Cryptographic scheme"
    def keygen(out)
      result = Soteria::CoreBridge.keygen(out: out, scheme: options[:scheme])
      puts JSON.pretty_generate(result)
    end

    desc "share SUBCOMMAND", "Manage volume sharing (add, remove, list, unlock)"
    subcommand "share", ShareCLI

    desc "verify DIR", "Verify volume integrity"
    def verify(dir)
      result = Soteria::CoreBridge.verify(dir: dir)
      puts JSON.pretty_generate(result)
    end

    desc "list DIR", "List volumes in a directory"
    def list(dir)
      result = Soteria::CoreBridge.list(dir: dir)
      puts JSON.pretty_generate(result)
    end

    desc "audit LOG", "Inspect audit log"
    option :verify_only, type: :boolean, default: false
    def audit(log)
      result = Soteria::CoreBridge.audit(log: log, verify_only: options[:verify_only])
      puts JSON.pretty_generate(result)
    end

    desc "status", "Show system status"
    def status
      admin = Soteria::Admin.new
      admin.status
    end

    desc "health DIR", "Run health check on volumes"
    def health(dir)
      admin = Soteria::Admin.new
      admin.health_check(dir)
    end

    desc "batch-encrypt FILES...", "Batch encrypt multiple files"
    option :into, required: true, desc: "Destination directory"
    option :passphrase, required: true, desc: "Encryption passphrase"
    option :fast_kdf, type: :boolean, default: false
    def batch_encrypt(*files)
      admin = Soteria::Admin.new
      admin.batch_encrypt(files, into: options[:into],
                          passphrase: options[:passphrase],
                          fast_kdf: options[:fast_kdf])
    end
  end

  # Nested share subcommand.
  class ShareCLI < Thor
    desc "add VOLUME", "Add a recipient to a volume"
    option :passphrase, required: true
    option :recipient_pk, required: true
    option :owner_sk, required: true
    def add(volume)
      result = Soteria::CoreBridge.share_add(
        volume: volume, passphrase: options[:passphrase],
        recipient_pk: options[:recipient_pk],
        owner_sk: options[:owner_sk]
      )
      puts JSON.pretty_generate(result)
    end

    desc "remove VOLUME", "Revoke a recipient"
    option :passphrase, required: true
    option :recipient_pk, required: true
    option :reason, default: "manual revocation"
    def remove(volume)
      result = Soteria::CoreBridge.share_remove(
        volume: volume, passphrase: options[:passphrase],
        recipient_pk: options[:recipient_pk],
        reason: options[:reason]
      )
      puts JSON.pretty_generate(result)
    end

    desc "list VOLUME", "List recipients"
    option :passphrase, required: true
    def list(volume)
      result = Soteria::CoreBridge.share_list(
        volume: volume, passphrase: options[:passphrase]
      )
      puts JSON.pretty_generate(result)
    end

    desc "unlock VOLUME", "Unlock volume with recipient key"
    option :sk, required: true
    option :out, required: true
    option :owner_pk
    option :no_verify_signature, type: :boolean, default: false
    def unlock(volume)
      result = Soteria::CoreBridge.share_unlock(
        volume: volume, sk: options[:sk], out: options[:out],
        owner_pk: options[:owner_pk],
        no_verify_signature: options[:no_verify_signature]
      )
      puts JSON.pretty_generate(result)
    end
  end
end

Soteria::CLI.start(ARGV)
