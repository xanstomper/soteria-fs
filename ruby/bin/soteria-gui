#!/usr/bin/env ruby
# frozen_string_literal: true

# Soteria GUI Launcher
# Launches the native desktop application.

require_relative "lib/soteria"
require_relative "lib/soteria/gui/app"

# Check if this is first run
config_dir = if Gem.win_platform?
  File.join(ENV["APPDATA"] || "C:\\Users\\Default\\AppData\\Roaming", "Soteria")
else
  "/etc/soteria"
end

setup_complete = File.exist?(File.join(config_dir, ".setup-complete"))

if setup_complete
  # Launch main app
  app = Soteria::GUI::App.new
  app.run
else
  # Launch setup wizard
  require_relative "lib/soteria/gui/setup_wizard"
  wizard = Soteria::GUI::SetupWizard.new
  wizard.run
end
