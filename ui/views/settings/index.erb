<% @page_title = "Settings" %>

<div class="space-y-8 fade-in">
  <!-- Security Mode -->
  <div class="card">
    <h3 class="font-semibold mb-4">Security Mode</h3>
    <div class="grid grid-cols-3 gap-4">
      <div class="p-4 rounded-card border border-surface-border cursor-pointer hover:border-soteria-accent/50 transition-colors <%= 'border-soteria-accent bg-soteria-accent/5' if @settings["mode"] == 'personal' %>">
        <div class="font-medium mb-1">Personal</div>
        <div class="text-xs text-[#8B8B9E]">Balanced protection for everyday use. Full disk encryption, automatic key management.</div>
        <div class="text-xs text-soteria-green mt-2">Performance: Negligible</div>
      </div>
      <div class="p-4 rounded-card border border-surface-border cursor-pointer hover:border-soteria-accent/50 transition-colors <%= 'border-soteria-accent bg-soteria-accent/5' if @settings["mode"] == 'professional' %>">
        <div class="font-medium mb-1">Professional</div>
        <div class="text-xs text-[#8B8B9E]">Enhanced security for sensitive work. Adds key rotation, audit logging, snapshots.</div>
        <div class="text-xs text-soteria-green mt-2">Performance: Minimal</div>
      </div>
      <div class="p-4 rounded-card border border-surface-border cursor-pointer hover:border-soteria-accent/50 transition-colors <%= 'border-soteria-accent bg-soteria-accent/5' if @settings["mode"] == 'fortress' %>">
        <div class="font-medium mb-1">Fortress</div>
        <div class="text-xs text-[#8B8B9E]">Maximum protection. Adds decoy protection, intrusion detection, aggressive key rotation.</div>
        <div class="text-xs text-soteria-amber mt-2">Performance: Slight</div>
      </div>
    </div>
  </div>

  <!-- Notifications -->
  <div class="card">
    <h3 class="font-semibold mb-4">Notifications</h3>
    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-sm font-medium">Security alerts</div>
          <div class="text-xs text-[#5A5A6E]">Notify when action is required</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" class="sr-only peer" <%= 'checked' if @settings.dig("notifications", "alerts") %>>
          <div class="w-9 h-5 bg-surface-elevated peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-[#5A5A6E] after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:bg-soteria-accent peer-checked:bg-soteria-accent/20"></div>
        </label>
      </div>
      <div class="flex items-center justify-between">
        <div>
          <div class="text-sm font-medium">Key rotation reminders</div>
          <div class="text-xs text-[#5A5A6E]">Remind when keys are due for rotation</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" class="sr-only peer" <%= 'checked' if @settings.dig("notifications", "rotation_reminders") %>>
          <div class="w-9 h-5 bg-surface-elevated peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-[#5A5A6E] after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:bg-soteria-accent peer-checked:bg-soteria-accent/20"></div>
        </label>
      </div>
      <div class="flex items-center justify-between">
        <div>
          <div class="text-sm font-medium">Recovery test reminders</div>
          <div class="text-xs text-[#5A5A6E]">Remind every 30 days to test your recovery key</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" class="sr-only peer" <%= 'checked' if @settings.dig("notifications", "recovery_reminders") %>>
          <div class="w-9 h-5 bg-surface-elevated peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-[#5A5A6E] after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:bg-soteria-accent peer-checked:bg-soteria-accent/20"></div>
        </label>
      </div>
    </div>
  </div>

  <!-- Advanced -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold">Advanced Mode</h3>
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" class="sr-only peer" id="advanced-toggle" <%= 'checked' if @settings["advanced_mode"] %>>
        <div class="w-9 h-5 bg-surface-elevated peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-[#5A5A6E] after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:bg-soteria-accent peer-checked:bg-soteria-accent/20"></div>
      </label>
    </div>
    <p class="text-sm text-[#8B8B9E]">
      Advanced mode shows technical details like raw audit logs, TPM diagnostics, key derivation parameters,
      and capability token viewers. These are intended for security professionals and power users.
    </p>
  </div>
</div>
