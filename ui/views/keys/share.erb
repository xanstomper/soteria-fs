<% @page_title = "File Sharing" %>

<div class="space-y-8 fade-in">
  <!-- Add recipient -->
  <div class="card">
    <h3 class="font-semibold mb-4">Share with a Recipient</h3>
    <p class="text-sm text-[#8B8B9E] mb-4">
      Wrap your volume's encryption key with a recipient's post-quantum public key.
      The envelope is signed with your ML-DSA-65 signing key.
    </p>
    <form hx-post="/share/add" hx-target="#share-result" class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Volume Path</label>
          <input type="text" name="volume" class="input" placeholder="/path/to/volume.sot">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Passphrase</label>
          <input type="password" name="passphrase" class="input">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Recipient Public Key</label>
          <input type="text" name="recipient_pk" class="input" placeholder="/path/to/alice.pk">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Owner Signing Key</label>
          <input type="text" name="owner_sk" class="input" placeholder="/path/to/owner.dsa.sk">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">
        <i data-lucide="user-plus" class="w-4 h-4"></i>
        Add Recipient
      </button>
    </form>
    <div id="share-result" class="mt-4"></div>
  </div>

  <!-- List recipients -->
  <div class="card">
    <h3 class="font-semibold mb-4">Active Recipients</h3>
    <form hx-get="/share" hx-target="#share-list" class="flex gap-4 mb-4">
      <input type="text" name="volume" class="input flex-1" placeholder="Volume path">
      <input type="password" name="passphrase" class="input flex-1" placeholder="Passphrase">
      <button type="submit" class="btn btn-secondary">List</button>
    </form>
    <div id="share-list">
      <% if @share_list %>
        <% if @share_list["active"]&.any? %>
          <div class="space-y-2">
            <% @share_list["active"].each do |r| %>
              <div class="flex items-center justify-between p-3 rounded-card bg-surface-elevated">
                <div class="font-mono text-xs"><%= r["recipient_key_id_hex"]&.first(16) %>...</div>
                <span class="severity-badge success">Active</span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-sm text-[#5A5A6E]">No active recipients.</div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
