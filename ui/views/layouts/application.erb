<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Soteria — <%= @page_title || "Security Platform" %></title>
  <link rel="stylesheet" href="/css/app.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            surface: { DEFAULT: '#12121A', elevated: '#1A1A24', border: '#2A2A3A' },
            soteria: { green: '#34D399', amber: '#FBBF24', red: '#F87171', blue: '#60A5FA', accent: '#6366F1' }
          },
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
          borderRadius: { card: '12px', panel: '16px' }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-[#0A0A0F] text-[#E8E8ED] font-sans min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <nav class="w-64 bg-surface border-r border-surface-border flex flex-col">
      <!-- Logo -->
      <div class="p-6 border-b border-surface-border">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-soteria-accent flex items-center justify-center">
            <i data-lucide="shield" class="w-5 h-5 text-white"></i>
          </div>
          <div>
            <span class="text-lg font-semibold">Soteria</span>
            <span class="block text-xs text-[#5A5A6E]">Powered by Aegis</span>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex-1 p-4 space-y-1 overflow-y-auto">
        <a href="/" class="nav-link<%= ' active' if request.path == '/' %>">
          <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
          <span>Dashboard</span>
        </a>
        <a href="/storage" class="nav-link<%= ' active' if request.path.start_with?('/storage') || request.path.start_with?('/domains') %>">
          <i data-lucide="hard-drive" class="w-4 h-4"></i>
          <span>Protection</span>
        </a>
        <a href="/threats" class="nav-link<%= ' active' if request.path.start_with?('/threats') %>">
          <i data-lucide="shield-alert" class="w-4 h-4"></i>
          <span>Threats</span>
        </a>
        <a href="/keys" class="nav-link<%= ' active' if request.path.start_with?('/keys') || request.path.start_with?('/share') %>">
          <i data-lucide="key" class="w-4 h-4"></i>
          <span>Keys</span>
        </a>
        <a href="/recovery" class="nav-link<%= ' active' if request.path.start_with?('/recovery') %>">
          <i data-lucide="life-buoy" class="w-4 h-4"></i>
          <span>Recovery</span>
        </a>

        <div class="pt-4 pb-2 px-3">
          <span class="text-xs font-medium text-[#5A5A6E] uppercase tracking-wider">System</span>
        </div>
        <a href="/devices" class="nav-link<%= ' active' if request.path.start_with?('/devices') %>">
          <i data-lucide="monitor" class="w-4 h-4"></i>
          <span>Devices</span>
        </a>
        <a href="/audit" class="nav-link<%= ' active' if request.path.start_with?('/audit') %>">
          <i data-lucide="scroll-text" class="w-4 h-4"></i>
          <span>Audit Log</span>
        </a>
        <a href="/settings" class="nav-link<%= ' active' if request.path.start_with?('/settings') %>">
          <i data-lucide="settings" class="w-4 h-4"></i>
          <span>Settings</span>
        </a>
        <a href="/learn" class="nav-link<%= ' active' if request.path.start_with?('/learn') %>">
          <i data-lucide="book-open" class="w-4 h-4"></i>
          <span>Learning Center</span>
        </a>
      </div>

      <!-- Footer -->
      <div class="p-4 border-t border-surface-border">
        <a href="/installer" class="flex items-center gap-2 text-xs text-[#5A5A6E] hover:text-[#8B8B9E] transition-colors">
          <i data-lucide="download" class="w-3 h-3"></i>
          <span>Run Setup Wizard</span>
        </a>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <!-- Top bar -->
      <header class="sticky top-0 z-10 bg-[#0A0A0F]/80 backdrop-blur-xl border-b border-surface-border px-8 py-4">
        <div class="flex items-center justify-between">
          <h1 class="text-xl font-semibold"><%= @page_title || "Dashboard" %></h1>
          <div class="flex items-center gap-4">
            <a href="/learn" class="text-[#5A5A6E] hover:text-[#8B8B9E] transition-colors" title="Help">
              <i data-lucide="help-circle" class="w-5 h-5"></i>
            </a>
            <a href="/settings" class="text-[#5A5A6E] hover:text-[#8B8B9E] transition-colors" title="Settings">
              <i data-lucide="settings" class="w-5 h-5"></i>
            </a>
          </div>
        </div>
      </header>

      <!-- Page content -->
      <div class="p-8">
        <% if @error %>
          <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-card text-soteria-red text-sm">
            <div class="flex items-center gap-2">
              <i data-lucide="alert-circle" class="w-4 h-4"></i>
              <span><%= h(@error) %></span>
            </div>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </div>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
