<% @page_title = "Setup Wizard" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <!-- Progress steps -->
  <div class="flex items-center justify-between">
    <div class="wizard-step">
      <div class="step-number active">1</div>
      <span class="text-sm font-medium">Welcome</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">2</div>
      <span class="text-sm text-[#5A5A6E]">Scan</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">3</div>
      <span class="text-sm text-[#5A5A6E]">Mode</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">4</div>
      <span class="text-sm text-[#5A5A6E]">Recovery</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">5</div>
      <span class="text-sm text-[#5A5A6E]">Protect</span>
    </div>
  </div>

  <!-- Welcome content -->
  <div class="card text-center py-12">
    <div class="w-20 h-20 rounded-2xl bg-soteria-accent/15 flex items-center justify-center mx-auto mb-6">
      <i data-lucide="shield" class="w-10 h-10 text-soteria-accent"></i>
    </div>
    <h2 class="text-2xl font-bold mb-3">Protect Your Device</h2>
    <p class="text-[#8B8B9E] mb-8 max-w-md mx-auto">
      Soteria will encrypt your files, set up intrusion detection, and create a recovery key.
      The whole process takes about 5 minutes.
    </p>

    <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto mb-8">
      <div class="text-center">
        <i data-lucide="lock" class="w-6 h-6 text-soteria-green mx-auto mb-2"></i>
        <div class="text-xs text-[#8B8B9E]">Your files stay private</div>
      </div>
      <div class="text-center">
        <i data-lucide="shield-check" class="w-6 h-6 text-soteria-green mx-auto mb-2"></i>
        <div class="text-xs text-[#8B8B9E]">Your system defends itself</div>
      </div>
      <div class="text-center">
        <i data-lucide="user-check" class="w-6 h-6 text-soteria-green mx-auto mb-2"></i>
        <div class="text-xs text-[#8B8B9E]">You stay in control</div>
      </div>
    </div>

    <a href="/installer/scan" class="btn btn-primary text-lg px-8 py-3">
      Get Started
      <i data-lucide="arrow-right" class="w-5 h-5"></i>
    </a>
  </div>
</div>
