<% @page_title = "Protection Mode" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <div class="flex items-center justify-between">
    <div class="wizard-step"><div class="step-number complete">1</div><span class="text-sm text-soteria-green">Welcome</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number complete">2</div><span class="text-sm text-soteria-green">Scan</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number active">3</div><span class="text-sm font-medium">Mode</span></div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step"><div class="step-number pending">4</div><span class="text-sm text-[#5A5A6E]">Recovery</span></div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step"><div class="step-number pending">5</div><span class="text-sm text-[#5A5A6E]">Protect</span></div>
  </div>

  <div class="card">
    <h2 class="text-lg font-semibold mb-2">Choose Protection Mode</h2>
    <p class="text-sm text-[#8B8B9E] mb-6">You can change this later at any time.</p>

    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="p-5 rounded-card border-2 border-soteria-accent bg-soteria-accent/5 cursor-pointer" data-mode="personal">
        <div class="font-semibold mb-2">Personal</div>
        <div class="text-xs text-[#8B8B9E] mb-3">Balanced protection for everyday use.</div>
        <div class="text-xs text-soteria-green">Recommended for most users</div>
        <ul class="mt-3 space-y-1 text-xs text-[#8B8B9E]">
          <li>✓ Full disk encryption</li>
          <li>✓ Automatic key management</li>
          <li>✓ Recovery key backup</li>
        </ul>
      </div>
      <div class="p-5 rounded-card border border-surface-border cursor-pointer hover:border-soteria-accent/30 transition-colors" data-mode="professional">
        <div class="font-semibold mb-2">Professional</div>
        <div class="text-xs text-[#8B8B9E] mb-3">Enhanced security for sensitive work.</div>
        <div class="text-xs text-soteria-blue">Best for business data</div>
        <ul class="mt-3 space-y-1 text-xs text-[#8B8B9E]">
          <li>✓ Everything in Personal</li>
          <li>✓ Stronger key rotation</li>
          <li>✓ Audit logging</li>
          <li>✓ Snapshot recovery</li>
        </ul>
      </div>
      <div class="p-5 rounded-card border border-surface-border cursor-pointer hover:border-soteria-accent/30 transition-colors" data-mode="fortress">
        <div class="font-semibold mb-2">Fortress</div>
        <div class="text-xs text-[#8B8B9E] mb-3">Maximum protection for high-risk environments.</div>
        <div class="text-xs text-soteria-amber">For high-risk users</div>
        <ul class="mt-3 space-y-1 text-xs text-[#8B8B9E]">
          <li>✓ Everything in Professional</li>
          <li>✓ Decoy protection</li>
          <li>✓ Intrusion detection</li>
          <li>✓ Aggressive key rotation</li>
        </ul>
      </div>
    </div>

    <div class="flex justify-end">
      <a href="/installer/recovery" class="btn btn-primary">
        Continue
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</div>
