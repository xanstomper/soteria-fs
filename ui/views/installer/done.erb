<% @page_title = "Setup Complete" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <div class="card text-center py-12">
    <div class="w-20 h-20 rounded-full bg-soteria-green/15 flex items-center justify-center mx-auto mb-6">
      <i data-lucide="shield-check" class="w-10 h-10 text-soteria-green"></i>
    </div>
    <h2 class="text-2xl font-bold mb-3">Soteria Active</h2>
    <p class="text-[#8B8B9E] mb-8">Your device is protected. Soteria will continue working in the background.</p>

    <div class="flex items-center justify-center gap-8 mb-8">
      <div class="text-center">
        <div class="text-3xl font-bold text-soteria-green"><%= @status["score"] || 98 %></div>
        <div class="text-xs text-[#5A5A6E]">Protection Score</div>
      </div>
      <div class="w-px h-12 bg-surface-border"></div>
      <div class="text-center">
        <div class="text-3xl font-bold"><%= format_bytes(@status["protected_bytes"] || 0) %></div>
        <div class="text-xs text-[#5A5A6E]">Protected</div>
      </div>
    </div>

    <div class="flex gap-3 justify-center">
      <a href="/" class="btn btn-primary">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        Open Dashboard
      </a>
      <a href="/learn" class="btn btn-secondary">
        <i data-lucide="book-open" class="w-4 h-4"></i>
        Take a Tour
      </a>
    </div>
  </div>
</div>
