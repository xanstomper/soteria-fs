<% @page_title = "Protecting Your Device" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <div class="card text-center py-12">
    <h2 class="text-lg font-semibold mb-8">Setting Up Protection</h2>

    <div class="space-y-6 max-w-md mx-auto">
      <div>
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm">Initializing Trust Chain</span>
          <span class="text-xs text-soteria-green">Complete</span>
        </div>
        <div class="progress-bar">
          <div class="fill bg-soteria-green" style="width: 100%"></div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm">Creating Secure Domains</span>
          <span class="text-xs text-soteria-green">Complete</span>
        </div>
        <div class="progress-bar">
          <div class="fill bg-soteria-green" style="width: 100%"></div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm">Protecting Storage</span>
          <span class="text-xs text-soteria-accent">In progress...</span>
        </div>
        <div class="progress-bar">
          <div class="fill bg-soteria-accent" style="width: 65%"></div>
        </div>
      </div>
    </div>

    <p class="text-sm text-[#5A5A6E] mt-8">
      Your files are being encrypted in the background. You can continue using your device.
    </p>
  </div>
</div>
