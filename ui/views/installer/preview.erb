<% @page_title = "Preview" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <div class="flex items-center justify-between">
    <div class="wizard-step"><div class="step-number complete">1</div><span class="text-sm text-soteria-green">Welcome</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number complete">2</div><span class="text-sm text-soteria-green">Scan</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number complete">3</div><span class="text-sm text-soteria-green">Mode</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number complete">4</div><span class="text-sm text-soteria-green">Recovery</span></div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step"><div class="step-number active">5</div><span class="text-sm font-medium">Protect</span></div>
  </div>

  <div class="card">
    <h2 class="text-lg font-semibold mb-6">Ready to Protect</h2>

    <div class="space-y-4 mb-6">
      <div class="flex items-center justify-between p-3 rounded-card bg-surface-elevated">
        <span class="text-sm text-[#8B8B9E]">Device</span>
        <span class="text-sm font-medium">WORKSTATION-01</span>
      </div>
      <div class="flex items-center justify-between p-3 rounded-card bg-surface-elevated">
        <span class="text-sm text-[#8B8B9E]">Protection Mode</span>
        <span class="text-sm font-medium">Personal</span>
      </div>
      <div class="flex items-center justify-between p-3 rounded-card bg-surface-elevated">
        <span class="text-sm text-[#8B8B9E]">Recovery</span>
        <span class="text-sm font-medium text-soteria-green">Configured</span>
      </div>
    </div>

    <div class="p-4 rounded-card border border-surface-border mb-6">
      <div class="text-sm font-medium mb-3">What Soteria will protect:</div>
      <div class="grid grid-cols-2 gap-2">
        <div class="flex items-center gap-2 text-sm text-[#8B8B9E]">
          <i data-lucide="check" class="w-4 h-4 text-soteria-green"></i>
          Documents
        </div>
        <div class="flex items-center gap-2 text-sm text-[#8B8B9E]">
          <i data-lucide="check" class="w-4 h-4 text-soteria-green"></i>
          Photos
        </div>
        <div class="flex items-center gap-2 text-sm text-[#8B8B9E]">
          <i data-lucide="check" class="w-4 h-4 text-soteria-green"></i>
          Applications
        </div>
        <div class="flex items-center gap-2 text-sm text-[#8B8B9E]">
          <i data-lucide="check" class="w-4 h-4 text-soteria-green"></i>
          System files
        </div>
      </div>
    </div>

    <div class="flex justify-between">
      <a href="/installer/recovery" class="btn btn-secondary">Back</a>
      <a href="/installer/deploy" class="btn btn-primary text-lg px-8 py-3">
        Start Protection
        <i data-lucide="shield" class="w-5 h-5"></i>
      </a>
    </div>
  </div>
</div>
