<% @page_title = "System Scan" %>

<div class="max-w-2xl mx-auto space-y-8 fade-in">
  <!-- Progress steps -->
  <div class="flex items-center justify-between">
    <div class="wizard-step">
      <div class="step-number complete">1</div>
      <span class="text-sm text-soteria-green">Welcome</span>
    </div>
    <div class="flex-1 h-px bg-soteria-green mx-3"></div>
    <div class="wizard-step">
      <div class="step-number active">2</div>
      <span class="text-sm font-medium">Scan</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">3</div>
      <span class="text-sm text-[#5A5A6E]">Mode</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">4</div>
      <span class="text-sm text-[#5A5A6E]">Recovery</span>
    </div>
    <div class="flex-1 h-px bg-surface-border mx-3"></div>
    <div class="wizard-step">
      <div class="step-number pending">5</div>
      <span class="text-sm text-[#5A5A6E]">Protect</span>
    </div>
  </div>

  <div class="card">
    <h2 class="text-lg font-semibold mb-6">Scanning Your Device</h2>
    <div class="space-y-4">
      <% checks = [
        { label: "Hardware Security", sublabel: "Your device has a built-in trust anchor.", status: @system_check["tpm"] },
        { label: "Boot Integrity", sublabel: "Your system verifies its own startup.", status: @system_check["secure_boot"] },
        { label: "Storage Ready", sublabel: "Your main drive is ready for protection.", status: @system_check["disk"] },
        { label: "Space Available", sublabel: "Enough room for protection overhead.", status: @system_check["space"] },
        { label: "Recovery Options", sublabel: "Multiple backup methods available.", status: @system_check["recovery"] }
      ] %>
      <% checks.each do |check| %>
        <div class="flex items-center gap-4 p-4 rounded-card border border-surface-border">
          <div class="flex-shrink-0">
            <% if check[:status] == "pass" %>
              <i data-lucide="check-circle" class="w-6 h-6 text-soteria-green"></i>
            <% elsif check[:status] == "warn" %>
              <i data-lucide="alert-circle" class="w-6 h-6 text-soteria-amber"></i>
            <% else %>
              <i data-lucide="x-circle" class="w-6 h-6 text-soteria-red"></i>
            <% end %>
          </div>
          <div class="flex-1">
            <div class="font-medium"><%= check[:label] %></div>
            <div class="text-xs text-[#8B8B9E]"><%= check[:sublabel] %></div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-6 flex justify-end">
      <a href="/installer/mode" class="btn btn-primary">
        Continue
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</div>
