<% @page_title = "Protection" %>

<div class="space-y-8 fade-in">
  <!-- Storage overview -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold">Protected Storage</h3>
      <a href="/storage/verify" class="btn btn-secondary text-xs">
        <i data-lucide="shield-check" class="w-3 h-3"></i>
        Verify All
      </a>
    </div>
    <div class="flex items-center gap-6">
      <div class="flex-1">
        <div class="flex items-baseline gap-2 mb-2">
          <span class="text-3xl font-bold"><%= format_bytes(@storage["encrypted_bytes"]) %></span>
          <span class="text-sm text-[#5A5A6E]">encrypted</span>
        </div>
        <div class="text-sm text-[#8B8B9E] mb-3">
          of <%= format_bytes(@storage["total_bytes"]) %> total storage
        </div>
        <%
          pct = @storage["total_bytes"].to_i > 0 ? (@storage["encrypted_bytes"].to_f / @storage["total_bytes"] * 100).to_i : 0
        %>
        <div class="progress-bar">
          <div class="fill bg-soteria-green" style="width: <%= pct %>%"></div>
        </div>
      </div>
      <div class="text-right">
        <div class="text-4xl font-bold" style="color: <%= pct >= 80 ? '#34D399' : pct >= 50 ? '#FBBF24' : '#F87171' %>"><%= pct %>%</div>
        <div class="text-xs text-[#5A5A6E]">Protected</div>
      </div>
    </div>
  </div>

  <!-- Domains -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold">Security Domains</h3>
      <button onclick="document.getElementById('create-domain-modal').classList.remove('hidden')"
              class="btn btn-primary text-xs">
        <i data-lucide="plus" class="w-3 h-3"></i>
        Create Domain
      </button>
    </div>
    <div class="space-y-3">
      <% if @domains["domains"]&.any? %>
        <% @domains["domains"].each do |domain| %>
          <a href="/domains/<%= domain['id'] %>" class="block card hover:border-soteria-accent/30 transition-colors">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-soteria-accent/15 flex items-center justify-center">
                  <i data-lucide="folder" class="w-5 h-5 text-soteria-accent"></i>
                </div>
                <div>
                  <div class="font-medium"><%= h(domain["name"]) %></div>
                  <div class="text-xs text-[#5A5A6E]"><%= h(domain["path"]) %></div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="text-right">
                  <div class="text-sm"><%= format_bytes(domain["encrypted_bytes"]) %></div>
                  <div class="text-xs text-[#5A5A6E]"><%= domain["file_count"] || 0 %> files</div>
                </div>
                <span class="severity-badge success">Protected</span>
              </div>
            </div>
          </a>
        <% end %>
      <% else %>
        <div class="text-center py-8 text-[#5A5A6E]">
          <i data-lucide="folder-open" class="w-8 h-8 mx-auto mb-2"></i>
          <div class="text-sm">No domains configured</div>
          <div class="text-xs mt-1">Create a domain to organize your protected storage.</div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Create domain modal -->
  <div id="create-domain-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="card w-full max-w-md">
      <h3 class="font-semibold mb-4">Create Security Domain</h3>
      <form hx-post="/domains" hx-target="#domain-result" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Domain Name</label>
          <input type="text" name="name" class="input" placeholder="e.g., Personal, Business, Archive">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Path</label>
          <input type="text" name="path" class="input" placeholder="/path/to/protected/folder">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Encryption</label>
          <select name="algorithm" class="input">
            <option value="xchacha20-poly1305">XChaCha20-Poly1305 (recommended)</option>
            <option value="aes-256-gcm">AES-256-GCM</option>
          </select>
        </div>
        <div class="flex gap-2 justify-end">
          <button type="button" onclick="document.getElementById('create-domain-modal').classList.add('hidden')"
                  class="btn btn-secondary">Cancel</button>
          <button type="submit" class="btn btn-primary">Create</button>
        </div>
      </form>
      <div id="domain-result" class="mt-4"></div>
    </div>
  </div>
</div>
