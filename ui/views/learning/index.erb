<% @page_title = "Learning Center" %>

<div class="space-y-8 fade-in">
  <div class="card">
    <h2 class="text-lg font-semibold mb-2">Understanding Your Security</h2>
    <p class="text-sm text-[#8B8B9E]">
      Learn how Soteria protects your files, without the technical jargon.
      Each topic has a simple explanation and an optional deep dive.
    </p>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <!-- Encryption -->
    <a href="/learn/encryption" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-green/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="lock" class="w-5 h-5 text-soteria-green"></i>
        </div>
        <div>
          <div class="font-medium mb-1">What is Encryption?</div>
          <div class="text-xs text-[#8B8B9E]">How your files are kept private, in simple terms.</div>
        </div>
      </div>
    </a>

    <!-- TPM -->
    <a href="/learn/tpm" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-blue/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="cpu" class="w-5 h-5 text-soteria-blue"></i>
        </div>
        <div>
          <div class="font-medium mb-1">Hardware Security (TPM)</div>
          <div class="text-xs text-[#8B8B9E]">How your device's security chip protects your keys.</div>
        </div>
      </div>
    </a>

    <!-- Key Rotation -->
    <a href="/learn/key-rotation" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-accent/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="refresh-cw" class="w-5 h-5 text-soteria-accent"></i>
        </div>
        <div>
          <div class="font-medium mb-1">Key Rotation</div>
          <div class="text-xs text-[#8B8B9E]">Why Soteria changes your encryption keys periodically.</div>
        </div>
      </div>
    </a>

    <!-- Canaries -->
    <a href="/learn/canaries" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-amber/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="bell" class="w-5 h-5 text-soteria-amber"></i>
        </div>
        <div>
          <div class="font-medium mb-1">Intrusion Detection</div>
          <div class="text-xs text-[#8B8B9E]">How canary tokens detect unauthorized access.</div>
        </div>
      </div>
    </a>

    <!-- Honey FS -->
    <a href="/learn/honey" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-amber/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="eye" class="w-5 h-5 text-soteria-amber"></i>
        </div>
        <div>
          <div class="font-medium mb-1">Decoy Protection</div>
          <div class="text-xs text-[#8B8B9E]">How fake files detect and trap intruders.</div>
        </div>
      </div>
    </a>

    <!-- Recovery -->
    <a href="/learn/recovery" class="card hover:border-soteria-accent/30 transition-colors">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-lg bg-soteria-green/15 flex items-center justify-center flex-shrink-0">
          <i data-lucide="life-buoy" class="w-5 h-5 text-soteria-green"></i>
        </div>
        <div>
          <div class="font-medium mb-1">Recovery Keys</div>
          <div class="text-xs text-[#8B8B9E]">Why recovery keys exist and how to keep them safe.</div>
        </div>
      </div>
    </a>
  </div>
</div>
