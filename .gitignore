# Rust
**/target/
**/*.rs.bk
# Cargo.lock is committed for binary crates (reproducible builds).
# Library-only crates may ignore it.

# Crush / opencode / local tool state
.crush/
.crush.json

# Ruby
ruby/vendor/
ruby/.bundle/
ruby/tmp/

# Desktop app
desktop/target/
desktop/dist/
desktop/node_modules/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Build artifacts
*.msix
*.dmg
*.deb
*.rpm
*.pkg
*.exe

# Test artifacts
*.sot
*.sot.kdf
*.sot.wal
*.sot.shares

# Keys (NEVER commit)
*.sk
*.pk
*.key
*.pfx
*.pem

# Temp
/tmp/
packaging/windows/package/
packaging/linux/rpm/
packaging/macos/Soteria.app/
